# URL del sitio en producción (sin barra final)
NEXT_PUBLIC_SITE_URL=https://piscinasmundofibra.cl

# Código de verificación de Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Base de datos PostgreSQL (Vercel Postgres, Supabase, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:5432/piscinas_mundo_fibra"

# NextAuth — en producción DEBE ser un secreto aleatorio fuerte (nunca el placeholder):
#   npx auth secret
#   openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
